###############################################################################
# Docker Compose
###############################################################################

LIGHTRAG_IMAGE_TAG=v1.5.0rc3
LIGHTRAG_BIND_HOST=0.0.0.0
LIGHTRAG_HOST_PORT=9621
LIGHTRAG_DEFAULT_WORKSPACE=default

POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=pg
POSTGRES_PASSWORD=pg
POSTGRES_DATABASE=pg


###############################################################################
# Security
###############################################################################

# API clients must send this key in the fixed LightRAG header: X-API-Key.
LIGHTRAG_API_KEY=replace-me

# WebUI login / JWT auth. Keep enabled when exposing WebUI outside localhost.
# Format: user:password,user2:password2
AUTH_ACCOUNTS=admin:replace-me
TOKEN_SECRET=replace-with-long-random-secret
TOKEN_EXPIRE_HOURS=48
GUEST_TOKEN_EXPIRE_HOURS=24
WHITELIST_PATHS=/health


###############################################################################
# Storage
###############################################################################

LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=NetworkXStorage

# Do not set POSTGRES_WORKSPACE for per-workspace instances. It overrides
# LIGHTRAG_DEFAULT_WORKSPACE inside PostgreSQL storages.

# text-embedding-3-large is 3072 dimensions; use halfvec indexes to avoid the
# pgvector HNSW fp32 index dimension limit.
POSTGRES_VECTOR_INDEX_TYPE=HNSW_HALFVEC


###############################################################################
# LLM
###############################################################################

# Base LLM. Used by EXTRACT / KEYWORD / QUERY / VLM roles unless overridden.
LLM_BINDING=openai
LLM_BINDING_HOST=https://api.openai.com/v1
LLM_BINDING_API_KEY=replace-me
LLM_MODEL=gpt-5-mini
LLM_TIMEOUT=180
MAX_ASYNC=4

# Optional role-specific overrides. Uncomment when you want cheaper extraction
# and a stronger final-query model, or a separate fast keyword model.
# EXTRACT_LLM_MODEL=gpt-5-mini
# KEYWORD_LLM_MODEL=gpt-5-mini
# QUERY_LLM_MODEL=gpt-5
# QUERY_MAX_ASYNC_LLM=2


###############################################################################
# Embeddings
###############################################################################

EMBEDDING_BINDING=openai
EMBEDDING_BINDING_HOST=https://api.openai.com/v1
EMBEDDING_BINDING_API_KEY=replace-me
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Set to true only when the provider API should receive a dimensions parameter.
EMBEDDING_SEND_DIM=false


###############################################################################
# Document Processing / Ingestion
###############################################################################

# Requires LightRAG v1.5.0+.
# Recommended default: native DOCX parser with table/equation analysis, then
# fallback to legacy parser with recursive chunking.
LIGHTRAG_PARSER=*:native-teP,*:legacy-R

# Alternatives:
# LIGHTRAG_PARSER=*:legacy-R   # stable plain-text behavior
# LIGHTRAG_PARSER=*:legacy-R!  # vector-only RAG without KG

CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=100
ENTITY_EXTRACTION_USE_JSON=true

# MAX_PARALLEL_INSERT triggers multiple LLM calls per document.
MAX_PARALLEL_INSERT=2

# Multimodal analysis. Keep disabled unless a VLM-capable model is configured.
VLM_PROCESS_ENABLE=false


###############################################################################
# Retrieval
###############################################################################

# TOP_K is mostly graph retrieval candidates: entities in local mode and
# relationships in global mode. LightRAG upstream default is 40.
TOP_K=40

# CHUNK_TOP_K controls how many text chunks are kept for context after chunk
# retrieval/reranking. Increase per query for broad questions.
CHUNK_TOP_K=12

COSINE_THRESHOLD=0.2
RELATED_CHUNK_NUMBER=5
MAX_ENTITY_TOKENS=6000
MAX_RELATION_TOKENS=8000
MAX_TOTAL_TOKENS=30000


###############################################################################
# LiteLLM Rerank
###############################################################################

# Disabled by default. To enable LiteLLM rerank, change RERANK_BINDING to cohere.
# LiteLLM exposes a Cohere-compatible /rerank endpoint:
# https://docs.litellm.ai/docs/rerank
RERANK_BINDING=null
RERANK_BY_DEFAULT=false

# RERANK_MODEL must match a model_name from LiteLLM proxy config.yaml.
RERANK_MODEL=rerank-english-v3.0
RERANK_BINDING_HOST=http://host.docker.internal:4000/rerank
RERANK_BINDING_API_KEY=replace-me

MIN_RERANK_SCORE=0.0
MAX_ASYNC_RERANK=4
RERANK_TIMEOUT=30

# Optional for rerankers with small per-document token limits.
RERANK_ENABLE_CHUNKING=false
RERANK_MAX_TOKENS_PER_DOC=4096
