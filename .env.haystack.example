HAYSTACK_POSTGRES_BIND_HOST=127.0.0.1
HAYSTACK_POSTGRES_HOST=localhost
HAYSTACK_POSTGRES_PORT=5433
HAYSTACK_POSTGRES_USER=sa
HAYSTACK_POSTGRES_PASSWORD=sa
HAYSTACK_POSTGRES_DATABASE=sa

HAYHOOKS_BIND_HOST=0.0.0.0
HAYHOOKS_PORT=1416
HAYHOOKS_LOG_LEVEL=INFO
HAYHOOKS_SHOW_TRACEBACKS=true

HAYSTACK_PGVECTOR_SCHEMA=public
HAYSTACK_PGVECTOR_TABLE_PREFIX=haystack_documents
HAYSTACK_PGVECTOR_LANGUAGE=simple
HAYSTACK_PGVECTOR_CREATE_EXTENSION=true
HAYSTACK_PGVECTOR_RECREATE_TABLE=false
HAYSTACK_PGVECTOR_VECTOR_TYPE=halfvec
HAYSTACK_PGVECTOR_VECTOR_FUNCTION=cosine_similarity
HAYSTACK_PGVECTOR_SEARCH_STRATEGY=hnsw
HAYSTACK_PGVECTOR_HNSW_EF_SEARCH=

HAYSTACK_EMBEDDING_MODEL=text-embedding-3-large
HAYSTACK_EMBEDDING_DIMENSION=3072
HAYSTACK_EMBEDDING_API_DIMENSIONS=
HAYSTACK_EMBEDDING_API_KEY=replace-me
HAYSTACK_EMBEDDING_API_BASE_URL=https://api.openai.com/v1
HAYSTACK_EMBEDDING_BATCH_SIZE=16

HAYSTACK_SPLIT_BY=word
HAYSTACK_SPLIT_LENGTH=250
HAYSTACK_SPLIT_OVERLAP=40
HAYSTACK_DEFAULT_TOP_K=10
